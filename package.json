{
  "name": "obsidian-mz-media-fetcher",
  "version": "0.3.4",
  "private": true,
  "description": "Create media and event notes from Bangumi, MobyGames, Bilibili Show, and Showstart.",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "install:dev": "node scripts/install-dev.mjs",
